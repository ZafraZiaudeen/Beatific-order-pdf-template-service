PDF_TEMPLATE_PORT=5055
PDF_TEMPLATE_BASE_URL=http://localhost:5055
PDF_TEMPLATE_OUTPUT_DIR=outputs
PDF_TEMPLATE_ALLOWED_ORIGINS=*
PDF_TEMPLATE_API_KEY=change-me-to-a-shared-random-secret

# Required in production so generated previews/PDFs are public and persistent.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxx

# Optional. Relative paths resolve from this service directory.
CANELA_FONT_DIR=fonts/Canela_Collection
